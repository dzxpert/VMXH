        <mxCell id="vmcs_f2" value="&lt;b&gt;Host State Area&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;CR0-4, RSP, RIP,&lt;br&gt;Segments, SYSENTER&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Segoe UI;fontSize=9;fontColor=#333;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="170" y="635" width="125" height="52" as="geometry"/>
        </mxCell>
        <mxCell id="vmcs_f3" value="&lt;b&gt;VM-Execution Ctls&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;Pin/Proc/2nd Proc,&lt;br&gt;Exception Bitmap, EPT&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Segoe UI;fontSize=9;fontColor=#333;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="305" y="635" width="125" height="52" as="geometry"/>
        </mxCell>
        <mxCell id="vmcs_f4" value="&lt;b&gt;VM-Exit Info&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;Exit Reason, Qual,&lt;br&gt;Instr Len, Intr Info&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Segoe UI;fontSize=9;fontColor=#333;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="635" width="120" height="52" as="geometry"/>
        </mxCell>
        <!-- eVMCS note -->
        <mxCell id="vmcs_note" value="💡 &lt;b&gt;Enlightened VMCS:&lt;/b&gt; Memory-mapped for nested (like VMCB!) — Clean Fields skip unchanged VMCS areas" style="text;html=1;align=center;fontSize=8;fontFamily=Segoe UI;fontColor=#b85450;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="700" width="520" height="40" as="geometry"/>
