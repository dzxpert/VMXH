        <!-- Permission Legend (right side of hook box) -->
        <mxCell id="perm_legend" value="&lt;table style=&quot;font-family:Segoe UI;font-size:9px;color:#555;&quot; cellpadding=&quot;2&quot;&gt;&lt;tr&gt;&lt;td colspan=&quot;2&quot;&gt;&lt;b style=&quot;color:#7b2d8e;&quot;&gt;Permission Key&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;R&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Read&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;W&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Write&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;X&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Execute&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;MTF&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Monitor Trap Flag (Intel)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;TF&lt;/b&gt;&lt;/td&gt;&lt;td&gt;RFLAGS.TF Trap Flag (AMD)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;#NPF&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Nested Page Fault&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;#DB&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Debug Exception&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;overflow=fill;rounded=1;fillColor=#ffffff;strokeColor=#d0b8e0;shadow=1;" vertex="1" parent="1">
