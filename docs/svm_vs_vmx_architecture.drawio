        <mxCell id="vmcs_f1" value="&lt;b&gt;Guest State Area&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;CR0-4, DR7, RSP, RIP,&lt;br&gt;RFLAGS, Segments, EFER&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Segoe UI;fontSize=9;fontColor=#333;shadow=1;" vertex="1" parent="1">
