        <mxCell id="t1_sublabel" parent="1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontFamily=Segoe UI;" value="&lt;font style=&quot;font-size:10px;&quot; color=&quot;#ef6c00&quot;&gt;&lt;i&gt;页表构建中，数据纹丝不动&lt;/i&gt;&lt;/font&gt;" vertex="1">
