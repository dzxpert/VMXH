        <mxCell id="cmp_vs_arrow" edge="1" parent="1" style="endArrow=none;html=1;strokeColor=#455a64;strokeWidth=1;dashed=1;" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="920" y="318" as="sourcePoint" />
