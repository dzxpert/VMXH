        <mxCell id="t1_code_bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#263238;strokeColor=#e65100;strokeWidth=1.5;arcSize=6;shadow=1;" value="" vertex="1">
          <mxGeometry height="100" width="380" x="80" y="348" as="geometry" />
        </mxCell>
        <mxCell id="t1_code_title" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontFamily=Consolas;fontColor=#ffcc80;" value="&lt;font style=&quot;font-size:9px;&quot; color=&quot;#ffcc80&quot;&gt;&lt;b&gt;EptInitialize() — Identity Map&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="16" width="300" x="92" y="352" as="geometry" />
        </mxCell>
        <mxCell id="t1_code" parent="1" style="text;html=1;align=left;verticalAlign=top;fontFamily=Consolas;whiteSpace=wrap;" value="&lt;font style=&quot;font-size:9px;&quot; color=&quot;#e0e0e0&quot;&gt;&lt;pre style=&quot;margin:0;font-family:Consolas;&quot;&gt;for (i = 0; i &amp;lt; 512; i++)           // 512 PDPT entries&lt;br&gt;  for (j = 0; j &amp;lt; 512; j++) {       // 512 PD entries&lt;br&gt;    PhysAddr = (i*512 + j) * 2MB;&lt;br&gt;    PD[i][j].PhysAddr = PhysAddr;  // → 指向自己!&lt;br&gt;  }&lt;br&gt;// 覆盖 512 × 512 × 2MB = &lt;b&gt;&lt;font color=&quot;#ffab40&quot;&gt;512 GB&lt;/font&gt;&lt;/b&gt; 恒等映射&lt;/pre&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="72" width="360" x="92" y="370" as="geometry" />
        </mxCell>
        <mxCell id="t1_key" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;strokeWidth=1.5;fontFamily=Segoe UI;shadow=1;align=center;" value="&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b&gt;关键:&lt;/b&gt; GPA == HPA&lt;br&gt;&lt;br&gt;每个 2MB 页表项的物理地址&lt;br&gt;&lt;b&gt;指向它自己&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#e65100&quot;&gt;PD[i][j].PhysAddr = PhysAddr&lt;/font&gt;&lt;br&gt;&lt;br&gt;整个 512GB 物理内存&lt;br&gt;全部恒等映射&lt;/font&gt;" vertex="1">
          <mxGeometry height="130" width="190" x="480" y="348" as="geometry" />
        </mxCell>
        <mxCell id="t1_dram_note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ff9800;strokeWidth=1;fontFamily=Segoe UI;dashed=1;dashPattern=5 3;align=center;" value="&lt;font style=&quot;font-size:10px;&quot; color=&quot;#e65100&quot;&gt;&lt;b&gt;⚠ Physical DRAM: 完全不变!&lt;/b&gt;&lt;br&gt;数据原地不动，仅在内核内存中&lt;br&gt;构建了一组页表结构&lt;/font&gt;" vertex="1">
          <mxGeometry height="65" width="178" x="690" y="355" as="geometry" />
        </mxCell>
