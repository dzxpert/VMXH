          </mxGeometry>
        </mxCell>
        <mxCell id="summary_bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2f1;strokeColor=#00695c;strokeWidth=2;arcSize=5;shadow=1;" value="" vertex="1">
          <mxGeometry height="60" width="820" x="60" y="990" as="geometry" />
        </mxCell>
        <mxCell id="summary_text" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Segoe UI;" value="&lt;font style=&quot;font-size:11px;&quot; color=&quot;#004d40&quot;&gt;&lt;b&gt;核心原理总结:&lt;/b&gt; 后加载虚拟化 = 在已运行的 OS 下方插入一层&lt;b&gt;透明的&lt;/b&gt;地址翻译层。恒等映射 (GPA==HPA) 保证插入前后&lt;b&gt;所有内存地址的翻译结果不变&lt;/b&gt;，&lt;br&gt;因此 OS 和所有应用程序完全无法察觉。这就是 &lt;b&gt;Blue Pill&lt;/b&gt; 技术的核心 — 不是把 OS 搬进虚拟机，而是在 OS 脚下悄悄铺了一层透明地板。&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="800" x="70" y="995" as="geometry" />
        </mxCell>
        <mxCell id="arch_ref" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Segoe UI;" value="&lt;font style=&quot;font-size:9px;&quot; color=&quot;#78909c&quot;&gt;&lt;b&gt;VMX Hypervisor Toolbox&lt;/b&gt; — Intel VT-x (EPT) / AMD-V (NPT) dual-backend architecture&lt;br&gt;Source: driver/ept.c · driver/npt.c · driver/vmx_init.c · driver/svm_init.c · driver/hv_mem.c&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="440" x="900" y="775" as="geometry" />
        </mxCell>
      </root>
