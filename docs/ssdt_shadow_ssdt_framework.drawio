        <mxCell id="ksdt" parent="1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=0.06;fillColor=#e3f2fd;strokeColor=#1565c0;strokeWidth=1.5;fontFamily=Segoe UI;fontSize=9;shadow=1;" value="&lt;b&gt;KSERVICE_TABLE_DESCRIPTOR&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;&quot; face=&quot;Consolas&quot;&gt;+0x00 Base  → KiServiceTable (LONG[])&lt;br&gt;+0x08 Count → NULL (x64)&lt;br&gt;+0x10 Limit → 服务数量&lt;br&gt;+0x18 Number→ KiArgumentTable&lt;/font&gt;" vertex="1">
