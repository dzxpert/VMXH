        <!-- Anti-Anti-Debug integration note -->
        <mxCell id="aad_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#fff9c4;strokeColor=#f9a825;strokeWidth=1.5;fontFamily=Segoe UI;fontSize=9;fontColor=#795548;shadow=1;" value="&lt;b&gt;Anti-Anti-Debug 集成&lt;/b&gt;&lt;br&gt;&lt;br&gt;以下 Exit Handler 委派给&lt;br&gt;anti_anti_debug.c 处理:&lt;br&gt;&lt;br&gt;• CPUID → AadHandleCpuid&lt;br&gt;  隐藏 Hypervisor 位, 伪造厂商&lt;br&gt;• DR_ACCESS → AadHandleDrAccess&lt;br&gt;  清零/伪造调试寄存器&lt;br&gt;• EXCEPTION → AadHandleException&lt;br&gt;  拦截 #DB/#BP 异常&lt;br&gt;• RDTSC → AadHandleRdtsc&lt;br&gt;  补偿调试暂停时间差" vertex="1">
          <mxGeometry x="1185" y="920" width="225" height="180" as="geometry" />
        </mxCell>

        <!-- Hook framework integration note -->
        <mxCell id="hook_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#e8f5e9;strokeColor=#43a047;strokeWidth=1.5;fontFamily=Segoe UI;fontSize=9;fontColor=#1b5e20;shadow=1;" value="&lt;b&gt;EPT Hook 引擎集成&lt;/b&gt;&lt;br&gt;&lt;br&gt;EPT_VIOLATION + MTF 配合:&lt;br&gt;&lt;br&gt;1. Execute → Hook 页面 (X-only)&lt;br&gt;2. R/W → 原始页面 (RW-only)&lt;br&gt;3. EPT Violation 触发切换&lt;br&gt;4. MTF 单步后恢复 X-only&lt;br&gt;&lt;br&gt;→ 对 PatchGuard 完全透明" vertex="1">
          <mxGeometry x="1445" y="920" width="205" height="155" as="geometry" />
        </mxCell>

        <!-- VMCALL magic note -->
        <mxCell id="vmcall_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#fce4ec;strokeColor=#e53935;strokeWidth=1.5;fontFamily=Segoe UI;fontSize=9;fontColor=#b71c1c;shadow=1;" value="&lt;b&gt;VMCALL 协议&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Consolas&quot;&gt;RAX = 0xDEADCAFE&lt;/font&gt;&lt;br&gt;  → Legacy 关机路径&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Consolas&quot;&gt;RAX = VMCALL_MAGIC|cmd&lt;/font&gt;&lt;br&gt;  → 新分发 (内存读写等)&lt;br&gt;&lt;br&gt;未知 VMCALL → 注入 #UD" vertex="1">
          <mxGeometry x="1685" y="920" width="185" height="140" as="geometry" />
