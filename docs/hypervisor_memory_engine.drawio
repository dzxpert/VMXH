        <mxCell id="compare_table" value="&lt;table style=&quot;font-size:8px;font-family:Segoe UI;border-collapse:collapse;width:100%;&quot;&gt;&lt;tr style=&quot;background:#424242;color:white;&quot;&gt;&lt;td style=&quot;padding:4px 6px;&quot;&gt;&lt;b&gt;特性&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:4px 6px;background:#1565c0;&quot;&gt;&lt;b&gt;IOCTL 路径&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:4px 6px;background:#6a1b9a;&quot;&gt;&lt;b&gt;VMCALL 路径&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;&lt;b&gt;入口&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;DeviceIoControl&lt;/td&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;VMCALL 指令&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;&lt;b&gt;PID→CR3&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;PsLookupProcess&lt;/td&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;调用者预解析&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;&lt;b&gt;VA→PA&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;HvGuestVaToPa&lt;/td&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;HvGuestVaToPa&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;&lt;b&gt;内存访问&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;(PVOID)PA 直接指针&lt;/td&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;(PVOID)PA 直接指针&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;&lt;b&gt;执行层级&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;Ring 0 驱动调用&lt;/td&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;Ring -1 完全处理&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;&lt;b&gt;Guest API 调用&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;PsLookup 等&lt;/td&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;&lt;font color=&quot;#2e7d32&quot;&gt;&lt;b&gt;完全无&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;&lt;b&gt;可检测性&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;驱动可被发现&lt;/td&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;&lt;font color=&quot;#2e7d32&quot;&gt;&lt;b&gt;几乎不可能&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;&lt;b&gt;跨页处理&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;while 循环切分&lt;/td&gt;&lt;td style=&quot;padding:3px 5px;border:1px solid #eee;&quot;&gt;while 循环切分&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;overflow=fill;" vertex="1" parent="1">
