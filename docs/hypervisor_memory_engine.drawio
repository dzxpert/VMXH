        <!-- VMCALL Codes -->
        <mxCell id="vmcall_read" value="&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b&gt;VMCALL (READ)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;font-family:Consolas;&quot;&gt;RAX = 0xCAFE0000 | 0x0001&lt;br&gt;RDX = &amp;amp;VMCALL_MEM_PARAMS&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#7b1fa2;strokeWidth=1.5;fontFamily=Segoe UI;shadow=1;arcSize=10;" vertex="1" parent="1">
