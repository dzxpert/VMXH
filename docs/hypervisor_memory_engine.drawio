        <!-- Protection Items -->
        <mxCell id="prot1" value="&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b&gt;ObRegisterCallbacks&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;&quot; color=&quot;#888&quot;&gt;剥离句柄权限 (PROCESS_VM_READ)&lt;br&gt;阻止 OpenProcess 获取读写权限&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffccbc;strokeColor=#e64a19;strokeWidth=1.5;fontFamily=Segoe UI;shadow=1;arcSize=10;" vertex="1" parent="1">
