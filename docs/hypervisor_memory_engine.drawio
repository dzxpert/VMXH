        <mxCell id="step5_num" value="&lt;font style=&quot;font-size:16px;&quot; color=&quot;#0d47a1&quot;&gt;&lt;b&gt;⑤&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fontFamily=Segoe UI;" vertex="1" parent="1">
