        </mxCell>
        <mxCell id="prot3" value="&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b&gt;监控 KeStackAttachProcess&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;&quot; color=&quot;#888&quot;&gt;检测可疑的进程上下文切换&lt;br&gt;阻止驱动级 Attach + Read&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffccbc;strokeColor=#e64a19;strokeWidth=1.5;fontFamily=Segoe UI;shadow=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="252" width="335" height="52" as="geometry" />
        </mxCell>
        <mxCell id="prot4" value="&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b&gt;扫描可疑驱动调用栈&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;&quot; color=&quot;#888&quot;&gt;栈回溯检测非法驱动调用&lt;br&gt;检查调用来源模块签名&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffccbc;strokeColor=#e64a19;strokeWidth=1.5;fontFamily=Segoe UI;shadow=1;arcSize=10;" vertex="1" parent="1">
