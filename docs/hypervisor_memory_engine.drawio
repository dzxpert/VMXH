          </mxGeometry>
        </mxCell>
        <mxCell id="step4_loop" value="&lt;font style=&quot;font-size:7px;&quot;&gt;&lt;b&gt;while(BytesDone &amp;lt; Size)&lt;/b&gt;&lt;br&gt;每页重新翻译 VA→PA&lt;br&gt;ChunkSize = min(剩余页, 剩余数据)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;strokeWidth=1;fontFamily=Segoe UI;shadow=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="945" y="514" width="170" height="35" as="geometry" />
