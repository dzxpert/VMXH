        <mxCell id="center_fn_copy" value="&lt;font style=&quot;font-size:7px;&quot; color=&quot;#e65100&quot;&gt;HvCopyGuestMemory()&lt;/font&gt;" style="text;html=1;align=center;fontFamily=Consolas;" vertex="1" parent="1">
