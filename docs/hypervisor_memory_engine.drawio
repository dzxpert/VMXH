        <mxCell id="prot2" value="&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b&gt;Hook NtReadVirtualMemory&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;&quot; color=&quot;#888&quot;&gt;拦截并拒绝对受保护进程的内存读取&lt;br&gt;SSDT Inline Hook / IAT Hook&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffccbc;strokeColor=#e64a19;strokeWidth=1.5;fontFamily=Segoe UI;shadow=1;arcSize=10;" vertex="1" parent="1">
