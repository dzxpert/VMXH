        <!-- Page size masks -->
        <mxCell id="mask_table" value="&lt;table style=&quot;font-size:7px;font-family:Consolas;border-collapse:collapse;&quot;&gt;&lt;tr style=&quot;background:#3949ab;color:white;&quot;&gt;&lt;td style=&quot;padding:2px 5px;&quot;&gt;&lt;b&gt;页大小&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:2px 5px;&quot;&gt;&lt;b&gt;地址掩码&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:2px 5px;&quot;&gt;&lt;b&gt;偏移掩码&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:1px 4px;border:1px solid #ddd;&quot;&gt;4KB&lt;/td&gt;&lt;td style=&quot;padding:1px 4px;border:1px solid #ddd;&quot;&gt;0x000FFFFFFFFFF000&lt;/td&gt;&lt;td style=&quot;padding:1px 4px;border:1px solid #ddd;&quot;&gt;bits[11:0]&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:1px 4px;border:1px solid #ddd;&quot;&gt;2MB&lt;/td&gt;&lt;td style=&quot;padding:1px 4px;border:1px solid #ddd;&quot;&gt;0x000FFFFFFFE00000&lt;/td&gt;&lt;td style=&quot;padding:1px 4px;border:1px solid #ddd;&quot;&gt;bits[20:0]&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:1px 4px;border:1px solid #ddd;&quot;&gt;1GB&lt;/td&gt;&lt;td style=&quot;padding:1px 4px;border:1px solid #ddd;&quot;&gt;0x000FFFFFC0000000&lt;/td&gt;&lt;td style=&quot;padding:1px 4px;border:1px solid #ddd;&quot;&gt;bits[29:0]&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="960" y="290" width="325" height="60" as="geometry" />
        </mxCell>

        <!-- Index macros -->
        <mxCell id="index_macros" value="&lt;font style=&quot;font-size:7px;font-family:Consolas;&quot;&gt;&lt;b&gt;#define&lt;/b&gt; PML4_INDEX(va)  (((va) &amp;gt;&amp;gt; 39) &amp;amp; 0x1FF)&lt;br&gt;&lt;b&gt;#define&lt;/b&gt; PDPT_INDEX(va)  (((va) &amp;gt;&amp;gt; 30) &amp;amp; 0x1FF)&lt;br&gt;&lt;b&gt;#define&lt;/b&gt; PD_INDEX(va)    (((va) &amp;gt;&amp;gt; 21) &amp;amp; 0x1FF)&lt;br&gt;&lt;b&gt;#define&lt;/b&gt; PT_INDEX(va)    (((va) &amp;gt;&amp;gt; 12) &amp;amp; 0x1FF)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#9e9e9e;strokeWidth=1;fontFamily=Consolas;shadow=1;arcSize=6;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="960" y="355" width="325" height="55" as="geometry" />
        </mxCell>

        <!-- SafeReadPhysU64 note -->
        <mxCell id="safe_read" value="&lt;font style=&quot;font-size:7px;&quot;&gt;&lt;b&gt;SafeReadPhysU64()&lt;/b&gt; — 每次读取 PTE 都用 __try/__except 保护&lt;br&gt;范围检查: PhysAddr &amp;lt; 512GB (EPT identity map 上限)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;strokeWidth=1;fontFamily=Segoe UI;fontSize=7;shadow=1;arcSize=6;align=left;spacingLeft=6;" vertex="1" parent="1">
