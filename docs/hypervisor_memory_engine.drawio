        <mxCell id="left_sub" value="&lt;font style=&quot;font-size:9px;&quot; color=&quot;#888&quot;&gt;Anti-Cheat / 内核保护 — 全部在 Guest 内部 (Ring 0)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Segoe UI;" vertex="1" parent="1">
