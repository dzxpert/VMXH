        <!-- VMCALL_MEM_PARAMS struct -->
        <mxCell id="vmcall_params" value="&lt;font style=&quot;font-size:8px;font-family:Consolas;&quot;&gt;&lt;b&gt;typedef struct _VMCALL_MEM_PARAMS {&lt;/b&gt;&lt;br&gt;    ULONG64  TargetCr3;&lt;br&gt;    ULONG64  TargetVa;&lt;br&gt;    ULONG64  BufferVa;&lt;br&gt;    ULONG    Size;&lt;br&gt;    NTSTATUS Status;  &lt;font color=&quot;#888&quot;&gt;// [out]&lt;/font&gt;&lt;br&gt;&lt;b&gt;} VMCALL_MEM_PARAMS;&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#7b1fa2;strokeWidth=1.5;fontFamily=Consolas;shadow=1;arcSize=6;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1345" y="198" width="415" height="90" as="geometry" />
