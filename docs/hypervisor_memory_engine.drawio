        <!-- Present bit checks -->
        <mxCell id="present_note" value="&lt;font style=&quot;font-size:7px;&quot; color=&quot;#c62828&quot;&gt;每级: 检查 bit[0] = PAGE_PRESENT · 不存在 → 返回 0 (失败)&lt;/font&gt;" style="text;html=1;align=left;fontFamily=Segoe UI;" vertex="1" parent="1">
