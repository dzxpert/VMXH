        </mxCell>
        <mxCell id="step5_text" value="&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b&gt;返回数据到 User Mode&lt;/b&gt;&lt;font style=&quot;font-size:8px;&quot; color=&quot;#555&quot;&gt; — STATUS_SUCCESS → DeviceIoControl 输出缓冲区 → 用户进程接收原始字节&lt;/font&gt;&lt;/font&gt;" style="text;html=1;align=left;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="462" y="570" width="700" height="20" as="geometry" />
        </mxCell>

        <!-- Step5 key point -->
        <mxCell id="step5_key" value="&lt;font style=&quot;font-size:8px;&quot; color=&quot;#0d47a1&quot;&gt;&lt;b&gt;零 API 调用 · 零句柄 · 零上下文切换 · 纯物理内存操作&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=right;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="950" y="575" width="330" height="18" as="geometry" />
