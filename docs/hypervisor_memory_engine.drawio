        </mxCell>

        <mxCell id="vmcall_step1" value="&lt;font style=&quot;font-size:9px;&quot;&gt;&lt;b&gt;① VM-Exit: EXIT_REASON_VMCALL&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;&quot;&gt;Hypervisor 捕获 VMCALL 指令&lt;br&gt;检查 RAX 魔数: (RAX &amp;amp; 0xFFFF0000) == 0xCAFE0000?&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ce93d8;strokeColor=#6a1b9a;strokeWidth=1.5;fontFamily=Segoe UI;shadow=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1345" y="310" width="415" height="52" as="geometry" />
        </mxCell>

        <mxCell id="vmcall_arr2" style="rounded=1;html=1;strokeColor=#6a1b9a;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1552" y="367" as="sourcePoint" />
            <mxPoint x="1552" y="380" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="vmcall_step2" value="&lt;font style=&quot;font-size:9px;&quot;&gt;&lt;b&gt;② 读取参数块: HvGuestVaToPa(CallerCR3, RDX)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;&quot;&gt;用调用者 CR3 翻译 RDX → 参数结构物理地址&lt;br&gt;Params = (PVMCALL_MEM_PARAMS)ParamsPa&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ce93d8;strokeColor=#6a1b9a;strokeWidth=1.5;fontFamily=Segoe UI;shadow=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1345" y="380" width="415" height="52" as="geometry" />
        </mxCell>

        <mxCell id="vmcall_arr3" style="rounded=1;html=1;strokeColor=#6a1b9a;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1552" y="437" as="sourcePoint" />
            <mxPoint x="1552" y="450" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="vmcall_step3" value="&lt;font style=&quot;font-size:9px;&quot;&gt;&lt;b&gt;③ PA-to-PA 拷贝 (纯物理地址操作)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;&quot;&gt;SrcPa = HvGuestVaToPa(TargetCr3, TargetVa)&lt;br&gt;DstPa = HvGuestVaToPa(CallerCr3, BufferVa)&lt;br&gt;RtlCopyMemory((PVOID)DstPa, (PVOID)SrcPa, Chunk)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ce93d8;strokeColor=#6a1b9a;strokeWidth=1.5;fontFamily=Segoe UI;shadow=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1345" y="450" width="415" height="65" as="geometry" />
        </mxCell>

        <mxCell id="vmcall_arr4" style="rounded=1;html=1;strokeColor=#6a1b9a;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1552" y="520" as="sourcePoint" />
            <mxPoint x="1552" y="533" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="vmcall_step4" value="&lt;font style=&quot;font-size:9px;&quot;&gt;&lt;b&gt;④ Params→Status = STATUS_SUCCESS&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;&quot;&gt;HvAdvanceGuestRip() → VMRESUME 返回 Guest&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ce93d8;strokeColor=#6a1b9a;strokeWidth=1.5;fontFamily=Segoe UI;shadow=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1345" y="533" width="415" height="40" as="geometry" />
        </mxCell>

        <!-- VMCALL Key Advantage -->
        <mxCell id="vmcall_key" value="&lt;font style=&quot;font-size:9px;&quot;&gt;&lt;b&gt;🔑 VMCALL 路径优势:&lt;/b&gt;&lt;br&gt;• EPT Identity Map: GPA == HPA&lt;br&gt;• 直接用物理地址当指针读写内存&lt;br&gt;• 连 MmMapIoSpace 都不需要调用&lt;br&gt;• 全程在 Ring -1 — 零 Guest API 痕迹&lt;br&gt;• HvHandleMemoryVmcall() 统一处理&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=10;fillColor=#fff9c4;strokeColor=#f9a825;strokeWidth=1.5;fontFamily=Segoe UI;shadow=1;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1345" y="585" width="415" height="90" as="geometry" />
        </mxCell>

