        <mxCell id="limits_title" value="&lt;font style=&quot;font-size:13px;&quot; color=&quot;#2e7d32&quot;&gt;&lt;b&gt;安全限制与保护机制&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Segoe UI;" vertex="1" parent="1">
          <mxGeometry x="815" y="685" width="220" height="22" as="geometry" />
        </mxCell>

        <mxCell id="limits_table" value="&lt;table style=&quot;font-size:9px;font-family:Segoe UI;border-collapse:collapse;width:100%;&quot;&gt;&lt;tr style=&quot;background:#2e7d32;color:white;&quot;&gt;&lt;td style=&quot;padding:4px 8px;width:35%;&quot;&gt;&lt;b&gt;限制项&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;&quot;&gt;&lt;b&gt;描述&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:4px 8px;border:1px solid #c8e6c9;background:#f1f8e9;&quot;&gt;&lt;b&gt;单次最大 64KB&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;border:1px solid #c8e6c9;&quot;&gt;VMX_MEM_MAX_SIZE = 64×1024&lt;br&gt;防止过大传输阻塞系统&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:4px 8px;border:1px solid #c8e6c9;background:#f1f8e9;&quot;&gt;&lt;b&gt;Pages 必须 Present&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;border:1px solid #c8e6c9;&quot;&gt;检查每级 PTE bit[0]&lt;br&gt;Swapped out 页 → 返回错误&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:4px 8px;border:1px solid #c8e6c9;background:#f1f8e9;&quot;&gt;&lt;b&gt;跨页自动切分&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;border:1px solid #c8e6c9;&quot;&gt;ChunkSize = 0x1000 - PageOffset&lt;br&gt;每页重新翻译 VA → PA&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:4px 8px;border:1px solid #c8e6c9;background:#f1f8e9;&quot;&gt;&lt;b&gt;不触发 Page Fault&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;border:1px solid #c8e6c9;&quot;&gt;不访问 Guest 虚拟地址&lt;br&gt;物理访问不经过 MMU 异常&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:4px 8px;border:1px solid #c8e6c9;background:#f1f8e9;&quot;&gt;&lt;b&gt;物理范围 &amp;lt; 512GB&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;border:1px solid #c8e6c9;&quot;&gt;EPT Identity Map 上限&lt;br&gt;超出范围 → SafeReadPhysU64 拒绝&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:4px 8px;border:1px solid #c8e6c9;background:#f1f8e9;&quot;&gt;&lt;b&gt;__try/__except 保护&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding:4px 8px;border:1px solid #c8e6c9;&quot;&gt;所有物理读写都有异常保护&lt;br&gt;损坏地址不会 BSOD&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;overflow=fill;" vertex="1" parent="1">
