        <!-- Center section - function labels -->
        <mxCell id="center_fn_read" value="&lt;font style=&quot;font-size:7px;&quot; color=&quot;#2e7d32&quot;&gt;HvReadGuestMemory()&lt;/font&gt;" style="text;html=1;align=center;fontFamily=Consolas;" vertex="1" parent="1">
