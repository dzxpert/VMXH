        <mxCell id="right_sub" value="&lt;font style=&quot;font-size:9px;&quot; color=&quot;#888&quot;&gt;纯 Ring -1 路径 — 连 MmMapIoSpace 都不需要&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Segoe UI;" vertex="1" parent="1">
