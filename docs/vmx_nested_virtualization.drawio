        <mxCell id="sc_host" value="&lt;b&gt;物理主机&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;Windows + Hyper-V&lt;br&gt;(L0 Hypervisor)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#b71c1c;strokeWidth=2;fontFamily=Segoe UI;fontSize=10;shadow=1;arcSize=8;" vertex="1" parent="1">
