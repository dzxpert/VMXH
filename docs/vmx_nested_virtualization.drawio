        <mxCell id="sc_ept_hook" value="&lt;b&gt;EPT Hook 框架&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;配置 &quot;EPT-12&quot; 页分裂&lt;br&gt;L0 合并为 EPT-02&lt;br&gt;→ 透明函数 Hook&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#880e4f;strokeWidth=2;fontFamily=Segoe UI;fontSize=10;shadow=1;arcSize=8;" vertex="1" parent="1">
