        <!-- EPT permissions -->
        <mxCell id="ept_perms" value="&lt;table style=&quot;font-size:8px;font-family:Segoe UI;border-collapse:collapse;&quot;&gt;&lt;tr&gt;&lt;td style=&quot;background:#b71c1c;color:white;padding:3px 6px;&quot; colspan=4&gt;&lt;b&gt;EPT PTE 权限位&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:2px 5px;border:1px solid #ddd;&quot;&gt;&lt;b&gt;R&lt;/b&gt; (bit 0)&lt;/td&gt;&lt;td style=&quot;padding:2px 5px;border:1px solid #ddd;&quot;&gt;&lt;b&gt;W&lt;/b&gt; (bit 1)&lt;/td&gt;&lt;td style=&quot;padding:2px 5px;border:1px solid #ddd;&quot;&gt;&lt;b&gt;X&lt;/b&gt; (bit 2)&lt;/td&gt;&lt;td style=&quot;padding:2px 5px;border:1px solid #ddd;&quot;&gt;&lt;b&gt;Memory Type&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:2px 5px;border:1px solid #ddd;background:#e8f5e9;&quot;&gt;Read&lt;/td&gt;&lt;td style=&quot;padding:2px 5px;border:1px solid #ddd;background:#fff3e0;&quot;&gt;Write&lt;/td&gt;&lt;td style=&quot;padding:2px 5px;border:1px solid #ddd;background:#ffccbc;&quot;&gt;Execute&lt;/td&gt;&lt;td style=&quot;padding:2px 5px;border:1px solid #ddd;background:#e8eaf6;&quot;&gt;WB/UC/...&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="525" y="710" width="350" height="60" as="geometry" />
        </mxCell>

        <!-- Hook key insight -->
        <mxCell id="hook_insight" value="&lt;font style=&quot;font-size:9px;&quot;&gt;&lt;b&gt;🔑 EPT Hook 核心原理:&lt;/b&gt;&lt;br&gt;同一 GPA 设置不同权限 →&lt;br&gt;执行时: X-only (Hook Page, 含 JMP)&lt;br&gt;读写时: RW-only (Original Page)&lt;br&gt;→ 代码修改对 Guest 完全不可见&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;size=12;fillColor=#fff9c4;strokeColor=#f9a825;strokeWidth=2;fontFamily=Segoe UI;shadow=1;align=left;spacingLeft=8;" vertex="1" parent="1">
