        <mxCell id="flow_title" value="&lt;b&gt;嵌套 VM-Exit 处理流程&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;fontFamily=Segoe UI;fontSize=11;fontColor=#0d47a1;" vertex="1" parent="1">
          <mxGeometry x="1610" y="140" width="200" height="20" as="geometry" />
        </mxCell>

        <mxCell id="fl1" value="&lt;b&gt;① L2 Guest 执行&lt;br&gt;敏感指令&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;&quot;&gt;CPUID / CR 访问 /&lt;br&gt;EPT Violation / ...&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;strokeWidth=1.5;fontFamily=Segoe UI;fontSize=9;shadow=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1630" y="170" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="fl2" value="&lt;b&gt;② VM-Exit → L0&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;&quot;&gt;硬件自动退出到&lt;br&gt;L0 Hypervisor&lt;br&gt;(跳过 L1!)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#b71c1c;strokeWidth=1.5;fontFamily=Segoe UI;fontSize=9;shadow=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1630" y="248" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="fl3" value="&lt;b&gt;③ L0 判断:&lt;br&gt;该由谁处理?&lt;/b&gt;" style="shape=mxgraph.flowchart.decision;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#0d47a1;strokeWidth=1.5;fontFamily=Segoe UI;fontSize=9;shadow=1;size=0.15;" vertex="1" parent="1">
          <mxGeometry x="1645" y="328" width="120" height="68" as="geometry" />
        </mxCell>

        <mxCell id="fl4a" value="&lt;b&gt;④a L0 自行处理&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;&quot;&gt;EPT-02 违规、&lt;br&gt;硬件级事件&lt;br&gt;→ 直接修复&lt;br&gt;→ VM-Resume L2&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#b71c1c;strokeWidth=1.5;fontFamily=Segoe UI;fontSize=9;shadow=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1790" y="333" width="130" height="75" as="geometry" />
        </mxCell>

        <mxCell id="fl4b" value="&lt;b&gt;④b 注入给 L1&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;&quot;&gt;L1 关注的事件&lt;br&gt;→ 模拟 VM-Exit 给 L1&lt;br&gt;→ L1 Hypervisor 处理&lt;br&gt;→ L1 执行 VMRESUME&lt;br&gt;→ L0 恢复 L2&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;strokeWidth=1.5;fontFamily=Segoe UI;fontSize=9;shadow=1;arcSize=10;" vertex="1" parent="1">
