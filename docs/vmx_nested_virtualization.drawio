        <mxCell id="hv_feat2" value="&lt;b&gt;Enlightenments&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;&quot;&gt;半虚拟化接口&lt;br&gt;L1 可感知嵌套&lt;br&gt;优化 TLB/IPI&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b2ebf2;strokeColor=#006064;strokeWidth=1.5;fontFamily=Segoe UI;fontSize=9;shadow=1;arcSize=8;" vertex="1" parent="1">
