        <mxCell id="sc_vm" value="&lt;b&gt;Hyper-V VM&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;Windows Guest&lt;br&gt;嵌套虚拟化已启用&lt;br&gt;(L1 Guest)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#e65100;strokeWidth=2;fontFamily=Segoe UI;fontSize=10;shadow=1;arcSize=8;" vertex="1" parent="1">
