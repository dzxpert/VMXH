        <!-- =================== Nested VMX Flow =================== -->
        <mxCell id="flow_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#0d47a1;strokeWidth=1.5;arcSize=5;" vertex="1" parent="1">
