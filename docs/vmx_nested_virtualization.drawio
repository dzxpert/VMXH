        <mxCell id="sc_vmxtoolbox" value="&lt;font color=&quot;#c62828&quot;&gt;&lt;b&gt;VMXToolboxDrv.sys&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;在 L1 VM 内加载&lt;br&gt;成为 L1 Hypervisor&lt;br&gt;创建 L2 执行环境&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffccbc;strokeColor=#d84315;strokeWidth=2;fontFamily=Segoe UI;fontSize=10;shadow=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="475" y="1012" width="155" height="65" as="geometry" />
